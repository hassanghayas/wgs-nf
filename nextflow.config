// def run_date = new Date().format("yyyyMMdd_HHmmss")

params {
    cpus  = 8
    memory = '16 GB'
    time = '6h'
    help = false
    annotation = false // default: do not run annotation
    mlst = false // default: do not run mlst
    amrfinder = false // default: do not run amrfinder
}

process {

    cpus = params.cpus
    memory = params.memory
    time = params.time
}

profiles {
    docker {
        process.executor = 'local'
        docker.enabled = true
    }
    singularity {
        process.executor = 'local'
        singularity.enabled = true
    }
    local {
        process.executor = 'local'
    }
    test {
        params.samplesheet = "$projectDir/test/samplesheet.csv"
        params.outdir      = "$launchDir/test_results"
    }
}

manifest {
  name        = 'hassanghayas/wgs-nf'
  version     = 'v1.2.0'
  description = 'Nextflow pipeline for bacterial genome assembly and annotation'
  author      = 'Hassan Ghayas'
}


report {
    enabled = true
    overwrite = true
    // file = "${params.outdir}/pipeline_info/execution_report_${run_date}.html"
    file = "${params.outdir}/pipeline_info/execution_report.html"
    
}

timeline {
    enabled = true
    overwrite = true
    // file = "${params.outdir}/pipeline_info/execution_timeline_${run_date}.html"
    file = "${params.outdir}/pipeline_info/execution_timeline.html"
}

trace {
    enabled = true
    overwrite = true
    // file = "${params.outdir}/pipeline_info/execution_trace_${run_date}.txt"
    file = "${params.outdir}/pipeline_info/execution_trace.txt"
}